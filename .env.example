# Secrets live in a git-ignored .env (BLUEPRINT 7); copy me to .env.
# Every path override must be absolute (REQ-CFG-001) -- tested against
# both path flavors, so ONE identical .env serves the NAS and the
# Windows box: a Windows CATCH_DIR is fine on Linux (the containers
# that never use it ignore it) and a POSIX DRIVE is fine on Windows.

# NAS host bind mount (compose maps ${DRIVE_NAS}:/data and forces
# DRIVE=/data inside the containers).
DRIVE_NAS=/volume1/media
# Windows library root (ignored on the NAS -- compose overrides DRIVE):
# DRIVE=C:\Users\a\My Drive

# One Telegram identity per bot (one getUpdates consumer per token).
# Docker side only: compose maps each TG_TOKEN_<BOT> to that
# container's TG_TOKEN. The Windows machine runs only print + catch
# (folder-driven, no tokens needed there).
TG_TOKEN_INBOX=
TG_TOKEN_FETCH=
TG_TOKEN_FAN_SAVE=
TG_TOKEN_FRAMES=
TG_TOKEN_CENSOR_BLUR=
TG_TOKEN_CENSOR_BLACK=
TG_TOKEN_RESTORE=
# moderator (admin panel: backend, clean, config, bed/wishlist status)
# and props (script -> prop list).
TG_TOKEN_MODERATOR=
TG_TOKEN_PROPS=
# donations: post each new donor alert (who/how much/question) to a chat.
TG_TOKEN_DONATIONS=
# wishlist: daily snapshot of a public wishlist; a vanished item is a gift.
TG_TOKEN_WISHLIST=

# aggregator is NOT a bot: it is a Telethon USER account (only a user account
# may send premium emoji). It listens to a source chat, groups a Short's
# per-platform links, and posts the collected message to the target chat(s).
# It uses API credentials, not a token -- get them from https://my.telegram.org.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Optional 2FA/cloud password for a non-interactive login (else prompted once):
# TELEGRAM_PASSWORD=
# The ONLY two aggregator knobs in the env: the monitoring chat and where to
# post. SOURCE_CHAT_ID is where the per-platform JSON messages arrive;
# TARGET_CHAT_ID is where the collected post is sent and is COMMA-SEPARATED --
# list several chats to post the same message to all of them. Defaults are
# baked in; set these to override:
# SOURCE_CHAT_ID=-1004402620527
# TARGET_CHAT_ID=-1002431466060
# TARGET_CHAT_ID=-1002431466060,-1009876543210
# Every other knob (platforms, title_match, timeout_sec, backfill,
# max_duration_sec, the field names, texts and emoji) lives in
# minions/aggregator/aggregator_constants.json, NOT here.
# Session file. In Docker, compose sets TELEGRAM_SESSION_FILE to a path on the
# /data mount (persists across restarts; log in once via
# `docker compose run --rm aggregator`, or drop a session file generated on
# Windows at <DRIVE_NAS>/bots/aggregator/telethon.session). Running WITHOUT
# Docker, the default is telethon.session next to minions/aggregator/
# (git-ignored, so it survives a repo re-sync). Same base name everywhere, so a
# file generated on Windows drops straight in. Point it elsewhere with:
# TELEGRAM_SESSION_FILE=/data/bots/aggregator/telethon

# Comma-separated chat allow-list, shared by all bots (the primary
# control, OPERATIONS 3): every listed chat may use every bot.
TG_CHATS=

# Model backend. Classification and the props bot default to GEMINI
# (fast; the local 7B is too slow on a low-power NAS CPU). The
# moderator bot flips to the local Qwen (Ollama) and back at
# runtime. Set GEMINI_API_KEY below. Background restore always uses
# Gemini regardless.
# MODEL_BACKEND=gemini                       (gemini | local; default gemini)
# OLLAMA_URL=http://ollama:11434             (the local 'gem' container)
# OLLAMA_MODEL=qwen2.5vl:7b   (prefer qwen2.5vl:3b on a slow CPU)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite        (image classification)
# GEMINI_BG_RESTORE_MODEL=gemini-3-pro-image (background restore)
# Gemini reasoning on the classify/props call. Default -1 = dynamic
# (on; flash-lite ships it off unless a budget is passed); 0 disables
# it; a positive number fixes the thinking-token budget.
# GEMINI_THINKING_BUDGET=-1

# Weekly script hints need no config: drop the week's Google Doc
# .gdoc shortcut(s) into _inbox/ (docs shared "Anyone with the link
# can view"). The next sort run consumes them and archives the text
# under Scripts/ for the rest of the week.

# donations bot: poll one or more donation platforms and post each new
# alert (who gave, how much, and their question) to DONATION_CHAT, in
# Russian. DONATION_PLATFORM is a comma-separated list -- run Streamlabs
# and Revolut together ("streamlabs,revolut"), each on its own cursor.
#   - STREAMLABS_TOKEN: the "Your API Access Token" from the Streamlabs
#     dashboard (Settings -> API Settings -> API Tokens tab) -- NOT the
#     Socket API Token; this bot polls the REST donations API.
#   - REVOLUT_TOKEN: a Revolut Business API access token (Bearer); the
#     bot reads incoming completed transactions as donations. Those
#     tokens are short-lived, so a long deployment refreshes it out of
#     band (the OAuth refresh flow is out of scope here).
# Only the SECRETS live here now: the tokens below. Every non-secret knob
# -- DONATION_CHAT, DONATION_PLATFORM, the poll interval, the bed
# auto-post timer/chat, WISHLIST_URL/CHAT and the enable toggles -- is a
# runtime setting the moderator edits from chat (persisted to
# bots/_data/state/admin.json). Send "config" to the moderator to list
# them, "set <key> <value>" to change one. See docs/BOTS.md. The env vars
# below still work as a seed/fallback if you prefer to set them here.
STREAMLABS_TOKEN=
REVOLUT_TOKEN=
# Non-secret seeds (or leave blank and use the moderator's admin panel):
DONATION_CHAT=
# DONATION_PLATFORM=streamlabs        (or e.g. streamlabs,revolut)

# wishlist bot (batch, cron-daily -- docker/crontab and
# deploy/crontab.example). Once a day it diffs a public wishlist: a
# vanished item is a gift, a new item is announced. Enable/disable, the
# URL, the chat and the digest toggle are all moderator settings (see
# docs/BOTS.md); the env vars below seed them. Public wishlist scraping is
# best-effort: an Amazon anti-bot page may need cookies/a proxy.
WISHLIST_URL=https://www.amazon.de/hz/wishlist/ls/YCM86K0NYW9P
WISHLIST_CHAT=

# Optional knobs (defaults in minion_core/settings.py):
# DOWNLOAD_TIMEOUT_SEC=900
# QUOTA_BYTES=34359738368
# YTDLP_FORMAT=bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best
# YTDLP_CONTAINER=mp4   (Telegram-friendly, inline preview; set mkv +
#   YTDLP_FORMAT=bestvideo*+bestaudio/best for max quality VP9/AV1)
# YTDLP_PLAYER_CLIENTS=default
# SOURCE_DIRS=  (extra sort source dirs; sort watches _inbox in Docker)
# SORT_WATCH=1  (set by the compose sort service; not a Windows knob)
# RELAY_PROGRESS_STYLE=blocks  (fetch/relay status bar theme:
#   blocks|shade|squares|emoji|donut|plant|spinner)
# RELAY_WORKERS=4  (concurrent downloads on a links belt -- many links from
#   many users run at once, up to this many; raise for more parallelism)
# SORT_TAU=0.75  (min image-image CLIP cosine to accept a fandom; below
#   it an image stays in Unknown instead of being forced into the nearest
#   fandom. Raise if unrelated photos get mislabelled, lower if real
#   fandom images pile up in Unknown.)
# FETCH_SINK=chat

# Windows print deployment (REQ-PRT-001; ';'-joined argv prefix). Leave
# PRINT_SPOOLER unset: run.cmd auto-locates SumatraPDF (LOCALAPPDATA /
# Program Files / PATH). Set it only to override that (a custom path, or
# `lp` on the NAS -- the compose image already defaults to lp):
# PRINT_SPOOLER=C:\Apps\SumatraPDF.exe;-print-to-default;-silent
# PRINT_TIMEOUT_SEC=120

# Second docks and catch (absolute paths; empty disables):
# CENSOR_BLUR_WATCH=C:\Users\a\My Drive\bots\censor-blur\drop
# CENSOR_BLACK_WATCH=C:\Users\a\My Drive\bots\censor-black\drop
# RESTORE_WATCH=C:\Users\a\My Drive\bots\restore\drop
# FRAMES_WATCH=C:\Users\a\My Drive\bots\frames\drop
# CATCH_DIR=C:\Users\a\Downloads

# Atomic services + web consumers (one compose project). The services are
# stateless (bytes in / bytes out); no store config. The one `telegram`
# container reaches each service by container name on the compose network
# (SERVICE_URL_* are set in docker-compose.yml, not here), and it reads the
# same TG_TOKEN_<BOT> above -- all Telegram identities live in that container.
# Only host ports are overridable:
# SVC_CENSOR_BLUR_PORT=8091   (curl -F file=@p.jpg :8091/run-file)
# SVC_CENSOR_BLACK_PORT=8092
# SVC_RESTORE_PORT=8093       (full restore; needs GEMINI_API_KEY in .env)
# SVC_FRAMES_PORT=8094        (frames come back as one zip)
# SVC_FETCH_PORT=8095         (link -> video; serves fetch + fan-save)
# REACTFLOW_PORT=8088         (canvas placeholder)
