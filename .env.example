# Secrets live in a git-ignored .env (BLUEPRINT 7); copy me to .env.
# Every path override must be absolute (REQ-CFG-001) -- tested against
# both path flavors, so ONE identical .env serves the NAS and the
# Windows box: a Windows CATCH_DIR is fine on Linux (the containers
# that never use it ignore it) and a POSIX DRIVE is fine on Windows.

# NAS host bind mount (compose maps ${DRIVE_NAS}:/data and forces
# DRIVE=/data inside the containers).
DRIVE_NAS=/volume1/media
# Windows library root (ignored on the NAS -- compose overrides DRIVE):
# DRIVE=C:\Users\a\My Drive

# One Telegram identity per bot (one getUpdates consumer per token).
# Docker side only: compose maps each TG_TOKEN_<BOT> to that
# container's TG_TOKEN. The Windows machine runs only print + catch
# (folder-driven, no tokens needed there).
TG_TOKEN_INBOX=
TG_TOKEN_FETCH=
TG_TOKEN_FAN_SAVE=
TG_TOKEN_FRAMES=
TG_TOKEN_CENSOR_BLUR=
TG_TOKEN_CENSOR_BLACK=
TG_TOKEN_RESTORE=
# model-switch (flip local <-> Gemini) and props (script -> prop list).
TG_TOKEN_MODEL_SWITCH=
TG_TOKEN_PROPS=

# Comma-separated chat allow-list, shared by all bots (the primary
# control, OPERATIONS 3): every listed chat may use every bot.
TG_CHATS=

# Model backend. Classification and the props bot default to GEMINI
# (fast; the local 7B is too slow on a low-power NAS CPU). The
# model-switch bot flips to the local Qwen (Ollama) and back at
# runtime. Set GEMINI_API_KEY below. Background restore always uses
# Gemini regardless.
# MODEL_BACKEND=gemini                       (gemini | local; default gemini)
# OLLAMA_URL=http://ollama:11434             (the local 'gem' container)
# OLLAMA_MODEL=qwen2.5vl:7b   (prefer qwen2.5vl:3b on a slow CPU)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite        (image classification)
# GEMINI_BG_RESTORE_MODEL=gemini-3-pro-image (background restore)
# Gemini reasoning on the classify/props call. Default -1 = dynamic
# (on; flash-lite ships it off unless a budget is passed); 0 disables
# it; a positive number fixes the thinking-token budget.
# GEMINI_THINKING_BUDGET=-1

# Weekly script hints need no config: drop the week's Google Doc
# .gdoc shortcut(s) into _inbox/ (docs shared "Anyone with the link
# can view"). The next sort run consumes them and archives the text
# under Scripts/ for the rest of the week.

# Optional knobs (defaults in minion_core/settings.py):
# DOWNLOAD_TIMEOUT_SEC=900
# QUOTA_BYTES=34359738368
# YTDLP_FORMAT=bestvideo*+bestaudio/best
# YTDLP_CONTAINER=mkv
# YTDLP_PLAYER_CLIENTS=default
# SOURCE_DIRS=  (extra sort source dirs; sort watches _inbox in Docker)
# SORT_WATCH=1  (set by the compose sort service; not a Windows knob)
# SORT_TAU=0.75  (min image-image CLIP cosine to accept a fandom; below
#   it an image stays in Unknown instead of being forced into the nearest
#   fandom. Raise if unrelated photos get mislabelled, lower if real
#   fandom images pile up in Unknown.)
# FETCH_SINK=chat

# Windows print deployment (REQ-PRT-001; ';'-joined argv prefix). Leave
# PRINT_SPOOLER unset: run.cmd auto-locates SumatraPDF (LOCALAPPDATA /
# Program Files / PATH). Set it only to override that (a custom path, or
# `lp` on the NAS -- the compose image already defaults to lp):
# PRINT_SPOOLER=C:\Apps\SumatraPDF.exe;-print-to-default;-silent
# PRINT_TIMEOUT_SEC=120

# Second docks and catch (absolute paths; empty disables):
# CENSOR_BLUR_WATCH=C:\Users\a\My Drive\bots\censor-blur\drop
# CENSOR_BLACK_WATCH=C:\Users\a\My Drive\bots\censor-black\drop
# RESTORE_WATCH=C:\Users\a\My Drive\bots\restore\drop
# FRAMES_WATCH=C:\Users\a\My Drive\bots\frames\drop
# CATCH_DIR=C:\Users\a\Downloads

# Atomic services + web consumers (one compose project). The services are
# stateless (bytes in / bytes out); no store config. The one `telegram`
# container reaches each service by container name on the compose network
# (SERVICE_URL_* are set in docker-compose.yml, not here), and it reads the
# same TG_TOKEN_<BOT> above -- all Telegram identities live in that container.
# Only host ports are overridable:
# SVC_CENSOR_BLUR_PORT=8091   (curl -F file=@p.jpg :8091/run-file)
# SVC_CENSOR_BLACK_PORT=8092
# SVC_RESTORE_PORT=8093       (full restore; needs GEMINI_API_KEY in .env)
# SVC_FRAMES_PORT=8094        (frames come back as one zip)
# SVC_FETCH_PORT=8095         (link -> video; serves fetch + fan-save)
# N8N_PORT=5678               (n8n editor)
# REACTFLOW_PORT=8088         (canvas placeholder)
