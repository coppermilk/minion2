# Secrets live in a git-ignored .env (BLUEPRINT 7); copy me to .env.
# Every path override must be absolute (REQ-CFG-001).

# Windows example: DRIVE=C:\Users\a\My Drive
# Docker: compose sets DRIVE=/data; set the host side instead:
DRIVE_NAS=/volume1/media

# One Telegram identity per bot (one getUpdates consumer per token).
# Docker side only: compose maps each TG_TOKEN_<BOT> to that
# container's TG_TOKEN. The Windows machine runs only print + catch
# (folder-driven, no tokens needed there).
TG_TOKEN_INBOX=
TG_TOKEN_FETCH=
TG_TOKEN_FAN_SAVE=
TG_TOKEN_FRAMES=
TG_TOKEN_CENSOR_BLUR=
TG_TOKEN_CENSOR_BLACK=
TG_TOKEN_RESTORE=

# Comma-separated chat allow-list, shared by all bots (the primary
# control, OPERATIONS 3): every listed chat may use every bot.
TG_CHATS=
GEMINI_API_KEY=

# Optional knobs (defaults in minion_core/settings.py):
# DOWNLOAD_TIMEOUT_SEC=900
# QUOTA_BYTES=34359738368
# YTDLP_FORMAT=bestvideo*+bestaudio/best
# YTDLP_CONTAINER=mkv
# YTDLP_PLAYER_CLIENTS=default
# SOURCE_DIRS=  (extra sort source dirs; sort watches _inbox in Docker)
# SORT_WATCH=1  (set by the compose sort service; not a Windows knob)
# FETCH_SINK=chat

# Windows print deployment (REQ-PRT-001; ';'-joined argv prefix):
# PRINT_SPOOLER=C:\Apps\SumatraPDF.exe;-print-to-default;-silent
# PRINT_TIMEOUT_SEC=120

# Second docks and catch (absolute paths; empty disables):
# CENSOR_BLUR_WATCH=C:\Users\a\My Drive\bots\censor-blur\drop
# CENSOR_BLACK_WATCH=C:\Users\a\My Drive\bots\censor-black\drop
# RESTORE_WATCH=C:\Users\a\My Drive\bots\restore\drop
# FRAMES_WATCH=C:\Users\a\My Drive\bots\frames\drop
# CATCH_DIR=C:\Users\a\Downloads
