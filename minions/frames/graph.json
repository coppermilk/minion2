{
  "bot": "frames",
  "stages": [
    {
      "merge": [
        {
          "source": "tg-any",
          "into": "spool",
          "dest": "spool",
          "help": "Send or drop a video (or a link) and I extract frames."
        },
        {
          "source": "folder",
          "root": "bot_dir",
          "into": "spool",
          "exts": [".mp4", ".mkv", ".webm", ".mov", ".avi"]
        }
      ]
    },
    { "step": "fetch" },
    { "step": "frames" },
    { "sink": "reply" },
    { "sink": "dispose-source", "locate": "spool" }
  ]
}
