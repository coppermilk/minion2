# Telethon user-account credentials -- get API_ID / API_HASH at https://my.telegram.org
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# Optional: your 2FA / cloud password. Only needed if the account has 2FA
# enabled AND you want a non-interactive run (server/cron). If omitted, you'll
# be prompted securely at login. It is used only to authenticate and is never
# stored in the session.
# TELEGRAM_PASSWORD=

# Session is saved as a FILE by default: telethon_premium_emoji.session next to
# main.py. Log in once and every later start is silent (survives restarts).
# Optional: put that file on a path that survives your machine's shutdowns
# (e.g. a mounted/persistent volume). The ".session" suffix is added for you.
# TELEGRAM_SESSION_FILE=/data/telethon_premium_emoji

# Optional: use a StringSession (in this env var) INSTEAD of a file on disk.
# Generate once with: python -c "from telethon.sessions import StringSession; from telethon import TelegramClient; import os; c=TelegramClient(StringSession(), int(os.environ['TELEGRAM_API_ID']), os.environ['TELEGRAM_API_HASH']); c.start(); print(c.session.save())"
# TELEGRAM_SESSION=

# Optional: override the proof-of-work target chat (defaults to the -100... id below).
# TARGET_CHAT_ID=-1002431466060

# --- post_bot.py (the BOT that posts inline premium emoji + a bottom button).
# A bot token from @BotFather. The button (inline keyboard) is bot-only, and
# premium emoji need the bot OWNER to have Telegram Premium.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# The bottom button's label and link. Set BUTTON_TEXT here (not in code) if you
# want a non-ASCII label, e.g. a Russian caption -- the .py source stays ASCII.
# BUTTON_TEXT=VIDEO
# BUTTON_URL=https://www.youtube.com/
