# Telethon user-account credentials — get API_ID / API_HASH at https://my.telegram.org
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# Optional: your 2FA / cloud password. Only needed if the account has 2FA
# enabled AND you want a non-interactive run (server/cron). If omitted, you'll
# be prompted securely at login. It is used only to authenticate and is never
# stored in the session.
# TELEGRAM_PASSWORD=

# Optional: a StringSession so you don't keep a .session file on disk.
# Generate once with: python -c "from telethon.sessions import StringSession; from telethon import TelegramClient; import os; c=TelegramClient(StringSession(), int(os.environ['TELEGRAM_API_ID']), os.environ['TELEGRAM_API_HASH']); c.start(); print(c.session.save())"
# TELEGRAM_SESSION=

# Optional: override the proof-of-work target chat (defaults to the -100… id below).
# TARGET_CHAT_ID=-1002431466060
