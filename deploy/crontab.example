# Bare-metal Linux host without the compose stack. Poll the batch bots
# every minute; each decides whether it is due from its own cron in
# admin.json (edited by the moderator: week_clean_cron, wishlist_cron).
# An off-schedule minute is a cheap no-op. sort is NOT scheduled here:
# run it as a watch daemon (SORT_WATCH=1) so new images sort instantly.

* * * * * cd /opt/bananaland && python -m minions.bots.week_clean.main >> "$DRIVE/bots/_data/logs/week-clean.cron.log" 2>&1

# wishlist: TG_TOKEN comes from TG_TOKEN_WISHLIST; WISHLIST_URL and
# WISHLIST_CHAT must be exported (e.g. from the .env) in cron's env.
* * * * * cd /opt/bananaland && TG_TOKEN="$TG_TOKEN_WISHLIST" python -m minions.bots.wishlist.main >> "$DRIVE/bots/_data/logs/wishlist.cron.log" 2>&1
